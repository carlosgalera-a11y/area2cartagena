# ══════════════════════════════════════════════════════════════════════
# Cartagenaeste — Variables de entorno
# ══════════════════════════════════════════════════════════════════════
# Este archivo es una PLANTILLA sin valores reales. Cópialo a `.env` (que
# está en .gitignore) y rellena con los valores locales.
#
# En PRODUCCIÓN estas variables NO viven aquí: se cargan desde
# Firebase Secret Manager (`firebase functions:secrets:set NOMBRE`).
# Este .env es solo para desarrollo local con emuladores.
# ══════════════════════════════════════════════════════════════════════

# ── Firebase Web (cliente) ──
# Claves públicas por diseño. Hardening via App Check + Referrer restrictions.
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# ── Cloud Functions secrets (backend europe-west1) ──
# Solo relevante si corres emuladores con estos valores. En prod → Secret Manager.
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
QWEN_API_KEY=
OPENROUTER_API_KEY=
DEEPL_API_KEY=

# ── Google Analytics 4 ──
GA4_MEASUREMENT_ID=

# ── reCAPTCHA v3 (App Check) ──
RECAPTCHA_SITE_KEY=

# ── Sentry (opcional, frontend error tracking) ──
SENTRY_DSN=

# ── Proxy local opt-in (solo Carlos, uso offline) ──
# Si se define, el frontend enruta peticiones IA por aquí antes que por
# la Cloud Function. En producción pública se deja VACÍO.
LOCAL_AI_PROXY=
