{
  "name": "cartagenaeste-functions",
  "version": "2.0.0",
  "description": "Cloud Functions para Cartagenaeste — askAi unificada en europe-west1",
  "main": "lib/index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test": "vitest run --exclude '**/firestore-rules.test.ts'",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --exclude '**/firestore-rules.test.ts'",
    "test:rules": "FIRESTORE_EMULATOR_HOST=127.0.0.1:8080 vitest run test/firestore-rules.test.ts",
    "lint": "eslint --ext .js,.ts ."
  },
  "dependencies": {
    "@sentry/google-cloud-serverless": "^8.40.0",
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^6.1.0",
    "google-auth-library": "^9.14.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.4",
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^2.1.0",
    "firebase": "^10.13.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.0"
  },
  "private": true
}
