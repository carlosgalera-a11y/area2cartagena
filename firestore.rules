rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuth() { return request.auth != null; }
    function isSuperAdmin() {
      return isAuth() && request.auth.token.email in [
        'ramongalera22@gmail.com','carlosgalera2roman@gmail.com','esther.montoro@gmail.com'
      ];
    }

    // Moderadores — read: authenticated, write: superadmin only
    match /moderadores/{docId} {
      allow read: if isAuth();
      allow create, update, delete: if isSuperAdmin();
    }

    // Propuestas — create: authenticated, moderate: admin/moderator, delete: superadmin
    match /propuestas_contenido/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && (isSuperAdmin() || 
        exists(/databases/$(database)/documents/moderadores/$(request.auth.token.email)));
      allow delete: if isSuperAdmin();
    }

    // Documentos aprobados — read: authenticated, write: admin/mod
    match /documentos_aprobados/{docId} {
      allow read: if isAuth();
      allow write: if isAuth() && (isSuperAdmin() || 
        exists(/databases/$(database)/documents/moderadores/$(request.auth.token.email)));
    }

    // Platform config — read: authenticated, write: superadmin
    match /platform_config/{docId} {
      allow read: if isAuth();
      allow write: if isSuperAdmin();
    }

    // AI Audit Log — create: authenticated, read: admin, no update/delete (immutable)
    match /ai_audit_log/{docId} {
      allow create: if isAuth();
      allow read: if isSuperAdmin();
      allow update, delete: if false;
    }

    // Config (legacy) — read: authenticated, write: superadmin
    match /config/{docId} {
      allow read: if isAuth();
      allow write: if isSuperAdmin();
    }

    // Informes IA — each user can only CRUD their own reports
    match /informes_ia/{docId} {
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow read, delete: if isAuth() && resource.data.uid == request.auth.uid;
      allow update: if false; // informes are immutable, generate a new one
    }

    // Default: deny all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
