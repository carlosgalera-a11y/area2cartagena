rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ══ Helpers ══════════════════════════════════════════════════════
    function signedIn() { return request.auth != null; }
    function isOwner(uid) { return signedIn() && request.auth.uid == uid; }
    // Admin via custom claim primary; hardcoded fallback para migración.
    function isAdmin() {
      return signedIn() && (
        request.auth.token.admin == true
        || request.auth.token.role == 'superadmin'
        || request.auth.token.role == 'admin'
        || request.auth.token.email == 'carlosgalera2roman@gmail.com'
      );
    }
    function noDni(text) {
      return text is string
        && !text.matches('.*[0-9]{8}[A-HJ-NP-TV-Zа-я].*')
        && !text.matches('.*[XYZ][0-9]{7}[A-HJ-NP-TV-Z].*');
    }
    // ══ Usuarios ════════════════════════════════════════════════════
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      // Usuario NO puede modificar su propio campo `role`.
      allow update: if isOwner(uid)
        && !('role' in request.resource.data.diff(resource.data).affectedKeys());
      allow delete: if isAdmin();

      // Casos docentes: DNI/NIE bloqueado, iniciales <= 4.
      match /cases/{cid} {
        allow read: if isOwner(uid) || isAdmin();
        allow create: if isOwner(uid)
          && request.resource.data.initials is string
          && request.resource.data.initials.size() <= 4
          && noDni(request.resource.data.get('notes', ''));
        allow update: if isOwner(uid)
          && noDni(request.resource.data.get('notes', ''));
        allow delete: if isOwner(uid) || isAdmin();
      }

      // AI requests: lectura dueño/admin; escritura solo server (Cloud Function).
      match /aiRequests/{rid} {
        allow read: if isOwner(uid) || isAdmin();
        allow create, update, delete: if false;
      }

      // Quotas: lectura propia; escritura solo server.
      match /quotas/{date} {
        allow read: if isOwner(uid);
        allow create, update, delete: if false;
      }

      // Progress: dueño lee/escribe.
      match /progress/{pid} {
        allow read, write: if isOwner(uid);
      }
    }

    // ══ AI Cache ════════════════════════════════════════════════════
    match /aiCache/{hash} {
      allow read: if signedIn();
      allow create, update, delete: if false;
    }

    // ══ Rate limit IP (solo server) ═════════════════════════════════
    match /rate_limits_ip/{id} {
      allow read, write: if false;
    }
    match /rate_limits/{id} {
      allow read, write: if false;
    }

    // ══ Informes IA — cada usuario CRUD de los suyos ═══════════════
    match /informes_ia/{docId} {
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow read, delete: if signedIn() && resource.data.uid == request.auth.uid;
      allow update: if signedIn() && resource.data.uid == request.auth.uid;
    }

    // ══ Per-user docs donde el docId == uid ════════════════════════
    match /mis_plantillas/{docId} {
      allow read, write: if signedIn() && docId == request.auth.uid;
    }
    match /mis_notebooks/{docId} {
      allow read, write: if signedIn() && docId == request.auth.uid;
    }
    match /megacuaderno_backups/{docId} {
      allow read, write: if signedIn() && docId == request.auth.uid;
    }
    match /plantillas_backup/{docId} {
      allow read, write: if signedIn() && docId == request.auth.uid;
    }

    // ══ Scan uploads ═══════════════════════════════════════════════
    match /scan_uploads/{docId} {
      allow create: if signedIn();
      allow read, update, delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    // ══ Guardia pacientes (CRUD propio) ════════════════════════════
    match /guardia_pacientes/{docId} {
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow read, update, delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    // ══ Triajes (QR) ═══════════════════════════════════════════════
    match /triajes/{docId} {
      allow create: if signedIn();
      // Read público (para que el paciente escanee QR sin login).
      allow read: if true;
      allow delete: if signedIn();
      allow update: if isAdmin();
    }

    // ══ Sugerencias: crear cualquier auth, leer admin ══════════════
    match /sugerencias/{docId} {
      allow create: if signedIn();
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }
    match /propuestas_contenido/{docId} {
      allow create: if signedIn();
      allow read: if signedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ══ Documentos aprobados — todos leen, admin escribe ══════════
    match /documentos_aprobados/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // ══ Moderadores/accesos (admin only) ═══════════════════════════
    match /moderadores/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
    match /accesos_profesionales/{docId} {
      allow read, write: if isAdmin();
    }

    // ══ Platform config / ai_audit_log (legacy) ═══════════════════
    match /platform_config/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
    match /ai_audit_log/{docId} {
      allow create: if signedIn();
      allow read: if isAdmin();
      allow update, delete: if false;
    }
    match /config/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // ══ Métricas (solo server escribe, admin lee) ══════════════════
    match /metrics_snapshots/{id} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    // ══ Audit log inmutable ════════════════════════════════════════
    match /auditLogs/{id} {
      allow read: if isAdmin();
      allow create: if false; // solo server (trigger Cloud Function)
      allow update, delete: if false;
    }

    // ══ Contadores de visitas públicas ═════════════════════════════
    // Permite increment +1 anónimo (uso: landing pacientes sin login).
    // Rule valida que count no decrezca y solo cambien campos permitidos.
    match /stats/{statDoc} {
      allow read: if isAdmin();
      allow create: if request.resource.data.keys().hasOnly(['count','updatedAt','lastVisit'])
                 && request.resource.data.count is int
                 && request.resource.data.count >= 0
                 && request.resource.data.count <= 1;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['count','updatedAt','lastVisit'])
                 && request.resource.data.count is int
                 && request.resource.data.count >= resource.data.count;
      allow delete: if isAdmin();
    }

    // ══ Centros (multi-tenancy, Fase 1) ════════════════════════════
    // Catálogo de centros/tenants. Lectura abierta para profesionales
    // autenticados (el cliente necesita el nombre, logo y color del
    // centro activo). Escritura sólo por superadmins.
    match /centros/{centroId} {
      allow read: if signedIn();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ══ Collection groups ═════════════════════════════════════════
    // Admin dashboard: lectura cross-user de aiRequests/quotas solo para admins.
    // Los usuarios siguen accediendo a su subcolección propia vía las reglas de
    // /users/{uid}/aiRequests por owner. Aquí habilitamos el collectionGroup.
    match /{path=**}/aiRequests/{rid} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }
    match /{path=**}/quotas/{date} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    // ══ DENY BY DEFAULT ════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
