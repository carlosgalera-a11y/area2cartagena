rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: verifica si el email es superadmin
    function isSuperAdmin() {
      return request.auth != null && (
        request.auth.token.email == "ramongalera22@gmail.com" ||
        request.auth.token.email == "carlosgalera2roman@gmail.com" ||
        request.auth.token.email == "esther.montoro@gmail.com"
      );
    }

    // Helper: usuario autenticado
    function isAuth() {
      return request.auth != null;
    }

    // === MODERADORES — solo superadmin puede escribir ===
    match /moderadores/{docId} {
      allow read: if isAuth();
      allow write: if isSuperAdmin();
    }

    // === PROPUESTAS DE CONTENIDO ===
    match /propuestas_contenido/{docId} {
      allow create: if isAuth()
                    && request.resource.data.email == request.auth.token.email;
      allow read: if isAuth();
      allow update: if isAuth();
      allow delete: if isSuperAdmin();
    }

    // === CONFIG — solo superadmin ===
    match /config/{docId} {
      allow read: if isAuth();
      allow write: if isSuperAdmin();
    }

    // === ACCESOS — log de visitas profesionales ===
    match /accesos/{docId} {
      allow create: if isAuth();
      allow read, update, delete: if isSuperAdmin();
    }

    // === ACCESOS_PROFESIONALES — log de páginas visitadas ===
    match /accesos_profesionales/{docId} {
      allow create: if isAuth();
      allow read, update, delete: if isSuperAdmin();
    }

    // === PROTOCOLOS — solo superadmin puede escribir ===
    match /protocolos/{docId} {
      allow read: if isAuth();
      allow write: if isSuperAdmin();
    }

    // === GUARDIA_CAMBIOS — registro de cambios de guardia ===
    match /guardia_cambios/{docId} {
      allow read, write: if isAuth();
    }

    // Bloquear todo lo demás
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
