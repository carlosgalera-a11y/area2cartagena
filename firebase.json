{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "*.md",
      "*.py",
      "*.sh",
      "docs/**",
      "functions-setup/**",
      "firebase-functions/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/notebook-local.html"
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
