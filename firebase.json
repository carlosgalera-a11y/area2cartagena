{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "*.md",
      "*.py",
      "ADMIN-CREDENTIALS.md",
      "FIREBASE-*.md",
      "MODERACION_SETUP.md",
      "SETUP.md",
      "README.md"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/notebook-local.html"
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
